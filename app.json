{
  "expo": {
    "name": "Rapid Capsule",
    "slug": "rapidcapusle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logomark.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "rapidcapusle",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rapidcapusle.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logomark.png",
        "backgroundColor": "#ffffff",
        "monochromeImage": "./assets/logomark.png"
      },
      "package": "com.rapidcapusle.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-tracking-transparency"]
  }
}
